NODE_ENV=development
PORT=3000
JWT_SECRET=change_me
JWT_EXPIRES_IN=1d

# Banco de desenvolvimento (ex.: Docker Compose na porta 5432).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/recipies_me?schema=public

# --- Arquivos opcionais (gitignored), carregados por src/config/loadEnv.ts ---
#
# Ordem: .env → .env.local → .env.${NODE_ENV}
# - `.env.local` — overrides pessoais (nunca commitar).
# - `.env.development` — só quando NODE_ENV=development (ex.: outro DATABASE_URL).
# - `.env.production` — só quando NODE_ENV=production (URL remota para teste local).
#
# Em produção no servidor: configure DATABASE_URL (e demais segredos) apenas nas variáveis
# do provedor; variáveis já definidas no ambiente não são sobrescritas pelo `.env`.
#
# Segurança: não compartilhe URLs com senha nem JWT em issues/chats; se vazou, troque a senha
# do banco no Supabase e gere novo JWT_SECRET.

# URL pública da API (opcional). Usada no OpenAPI/Swagger para "Try it out".
# API_PUBLIC_URL=http://localhost:3000

# Com NODE_ENV=development o Swagger está sempre ativo (/api-docs).
# Em production fica desligado por padrão; use ENABLE_SWAGGER=true para expor.
# Em test: omitido = ativo; ENABLE_SWAGGER=false desliga.
# ENABLE_SWAGGER=false
